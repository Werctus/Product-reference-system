<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.volkov.cw.controller.DashboardController">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

    <TitledPane text="Статус инвентаря" expanded="true" animated="true">
        <VBox spacing="16">
            <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
            <HBox spacing="16">
                <VBox HBox.hgrow="ALWAYS" maxWidth="280" style="-fx-background-color: #e3f2fd; -fx-background-radius: 8; -fx-padding: 15;">
                    <Label text="Всего товаров" style="-fx-font-size: 14px;"/>
                    <Label fx:id="totalProductsLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1976d2;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" maxWidth="280" style="-fx-background-color: #ffebee; -fx-background-radius: 8; -fx-padding: 15;">
                    <Label text="Товары с низким запасом" style="-fx-font-size: 14px;"/>
                    <Label fx:id="lowStockLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #d32f2f;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" maxWidth="280" style="-fx-background-color: #e8f5e9; -fx-background-radius: 8; -fx-padding: 15;">
                    <Label text="Всего магазинов" style="-fx-font-size: 14px;"/>
                    <Label fx:id="totalStoresLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #388e3c;"/>
                </VBox>
            </HBox>
        </VBox>
    </TitledPane>

    <TitledPane text="Быстрые действия - Отчёты Excel" expanded="true" animated="true">
        <VBox spacing="16">
            <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

            <!-- Отчёт по поставкам -->
            <TitledPane text="Отчёт по поставкам" expanded="true">
                <VBox spacing="10">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Дата с:" style="-fx-font-weight: bold;"/>
                        <DatePicker fx:id="dpSuppliesFrom" promptText="Выберите дату"/>
                        <Label text="Дата по:" style="-fx-font-weight: bold;"/>
                        <DatePicker fx:id="dpSuppliesTo" promptText="Выберите дату"/>
                    </HBox>
                    <Button text="📊 Сгенерировать отчёт по поставкам (Excel)"
                            onAction="#handleSuppliesReport"
                            maxWidth="Infinity"
                            style="-fx-background-color: #2196f3; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12;"/>
                </VBox>
            </TitledPane>

            <!-- Отчёт по изменению цен -->
            <TitledPane text="Отчёт по изменению цен" expanded="true">
                <VBox spacing="10">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Дата с:" style="-fx-font-weight: bold;"/>
                        <DatePicker fx:id="dpPriceFrom" promptText="Выберите дату"/>
                        <Label text="Дата по:" style="-fx-font-weight: bold;"/>
                        <DatePicker fx:id="dpPriceTo" promptText="Выберите дату"/>
                    </HBox>
                    <Button text="📈 Сгенерировать отчёт по ценам (Excel)"
                            onAction="#handlePriceChangesReport"
                            maxWidth="Infinity"
                            style="-fx-background-color: #9c27b0; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12;"/>
                </VBox>
            </TitledPane>
        </VBox>
    </TitledPane>
</VBox>