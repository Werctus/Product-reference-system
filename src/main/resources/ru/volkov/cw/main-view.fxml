<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ru.volkov.cw.controller.MainController">

    <top>
        <HBox alignment="CENTER" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="%app.title" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Label text="🌐" style="-fx-text-fill: white; -fx-font-size: 18px;"/>
                <ComboBox fx:id="cbLanguage" prefWidth="150" style="-fx-background-radius: 5;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE">
            <Tab text="%tab.products" closable="false">
                <fx:include fx:id="product" source="product-view.fxml" />
            </Tab>
            <Tab text="%tab.categories" closable="false">
                <fx:include fx:id="category" source="category-view.fxml" />
            </Tab>
            <Tab text="%tab.stores" closable="false">
                <fx:include fx:id="store" source="store-view.fxml" />
            </Tab>
            <Tab text="%tab.companies" closable="false">
                <fx:include fx:id="company" source="company-view.fxml" />
            </Tab>
            <Tab text="%tab.deliveries" closable="false">
                <fx:include fx:id="delivery" source="delivery-view.fxml" />
            </Tab>
            <Tab text="%tab.priceHistory" closable="false">
                <fx:include fx:id="priceHistory" source="pricehistory-view.fxml" />
            </Tab>
            <Tab text="%tab.references" closable="false">
                <fx:include fx:id="references" source="references-view.fxml" />
            </Tab>
            <Tab text="%tab.reports" closable="false">
                <fx:include fx:id="dashboard" source="dashboard-view.fxml" />
            </Tab>
        </TabPane>
    </center>

    <bottom>
        <HBox style="-fx-background-color: #34495e; -fx-padding: 8;">
            <Label fx:id="lblStatusBar" text="%status.ready" style="-fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="%status.lastSync" style="-fx-text-fill: #bdc3c7;"/>
            <Label fx:id="lblLastSync" text="--:--:--" style="-fx-text-fill: #ecf0f1; -fx-font-weight: bold;"/>
        </HBox>
    </bottom>
</BorderPane>