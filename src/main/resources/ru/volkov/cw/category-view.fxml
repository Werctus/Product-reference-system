<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.volkov.cw.controller.CategoryController">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
    <center>
        <TreeView fx:id="treeCategories" style="-fx-background-color: #ffffff; -fx-border-color: #dce4ec; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;">
            <padding><Insets top="5" right="5" bottom="5" left="5"/></padding>
        </TreeView>
    </center>
    <right>
        <VBox spacing="10" prefWidth="280">
            <padding><Insets left="15"/></padding>
            <Label text="%category.details" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Separator/>
            <Label text="%category.name" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <TextField fx:id="txtCategoryName" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #bdc3c7; -fx-padding: 5;"/>
            <Label text="%category.parent" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <ComboBox fx:id="cbParentCategory" promptText="%category.parent.select" style="-fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #bdc3c7; -fx-padding: 3;"/>
            <Separator/>
            <HBox spacing="10" alignment="CENTER">
                <Button text="%button.save" fx:id="btnSaveCategory" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-pref-width: 100; -fx-padding: 8;"/>
                <Button text="%button.delete" fx:id="btnDeleteCategory" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-pref-width: 100; -fx-padding: 8;"/>
            </HBox>
        </VBox>
    </right>
</BorderPane>