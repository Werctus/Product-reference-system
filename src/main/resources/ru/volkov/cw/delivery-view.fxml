<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.volkov.cw.controller.DeliveryController">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

    <HBox spacing="10">
        <Button text="%delivery.new" fx:id="btnAddDelivery" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
        <Button text="%button.edit" fx:id="btnEditDelivery" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button text="%button.delete" fx:id="btnDeleteDelivery" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
        <Button text="%delivery.changeStatus" fx:id="btnChangeStatus" style="-fx-background-color: #f39c12; -fx-text-fill: white;"/>

        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <TableView fx:id="tableDeliveries" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="%delivery.docNumber" fx:id="colDelNum" prefWidth="150"/>
            <TableColumn text="%delivery.company" fx:id="colDelComp" prefWidth="200"/>
            <TableColumn text="%store.name" fx:id="colDelStore" prefWidth="180"/>
            <TableColumn text="%delivery.status" fx:id="colDelStatus" prefWidth="150"/>
            <TableColumn text="%delivery.createdAt" fx:id="colDelDate" prefWidth="180"/>
        </columns>
    </TableView>

    <TitledPane text="%delivery.items" expanded="false" fx:id="deliveryItemsPane">
        <VBox spacing="10">
            <TableView fx:id="tableDeliveryItems" prefHeight="200">
                <columns>
                    <TableColumn text="%product.name" fx:id="colDeliveryItemProduct" prefWidth="250"/>
                    <TableColumn text="%delivery.qty" fx:id="colDeliveryItemQuantity" prefWidth="100"/>
                    <TableColumn text="%delivery.priceUnit" fx:id="colDeliveryItemPrice" prefWidth="120"/>
                    <TableColumn text="%delivery.total" fx:id="colDeliveryItemTotal" prefWidth="120"/>
                </columns>
            </TableView>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Label text="%delivery.totalAmount" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblDeliveryTotal" text="0.00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                <Button text="Изменить" fx:id="btnEditDeliveryItem" disable="true" style="-fx-background-color: #f39c12; -fx-text-fill: white;"/>
                <Button text="Удалить" fx:id="btnDeleteDeliveryItem" disable="true" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
                <Button text="%delivery.addItem" fx:id="btnAddDeliveryItem" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </TitledPane>
</VBox>