<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.volkov.cw.controller.StoreController">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
    <HBox spacing="10">
        <Button text="%button.add" fx:id="btnAddStore" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
        <Button text="%button.edit" fx:id="btnEditStore" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button text="%button.delete" fx:id="btnDeleteStore" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
    </HBox>
    <TableView fx:id="tableStores" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="%store.name" fx:id="colStoreName" prefWidth="200"/>
            <TableColumn text="%store.address" fx:id="colStoreAddress" prefWidth="250"/>
            <TableColumn text="%store.phone" fx:id="colStorePhone" prefWidth="150"/>
            <TableColumn text="Email" fx:id="colStoreEmail" prefWidth="200"/>
        </columns>
    </TableView>
    <TitledPane text="%store.inventory" fx:id="storeInventoryPane">
        <!-- Подключаем инвентарь как отдельный контроллер -->
        <fx:include fx:id="inventory" source="inventory-view.fxml" />
    </TitledPane>
</VBox>